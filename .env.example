# ============================================================
# LOCAL execution (.env)
# Used when running scripts directly on the host machine.
# Docker containers use docker-compose.yml environment instead.
# ============================================================

# --- MongoDB ---
MONGO_URI=mongodb://localhost:27017
MONGO_DB=commerce

# --- Auth ---
JWT_SECRET_KEY=changeme-use-a-long-random-string-in-production

# --- Vector DB (Qdrant) ---
QDRANT_HOST=localhost
QDRANT_PORT=6333
VECTOR_STORE_BACKEND=qdrant

# --- OpenAI (Semantic Search) ---
OPENAI_API_KEY=sk-...
